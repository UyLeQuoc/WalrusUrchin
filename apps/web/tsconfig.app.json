{
  "extends": "@workspace/ts-config/react.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["vite/client"],

    /* Bundler mode */
    "allowImportingTsExtensions": true,

    /* Linting */
    "erasableSyntaxOnly": true,
    "paths": {
      "@/*": ["./src/*"],
      "@workspace/cores/*": ["../../packages/cores/src/*"]
    }
  },
  "include": ["src"]
}
